generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERVISOR
  MEMBER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String
  role         Role      @default(MEMBER)
  totalBudget  Float     @default(0)
  receivedAmount Float   @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  expenses     Expense[]
  funds        Fund[]
  notifications Notification[]

  @@index([role])
  @@index([email])
}

model Expense {
  id           String   @id @default(cuid())
  title        String
  description  String?
  amount       Float
  editCount    Int      @default(0)
  category     String
  status       ExpenseStatus   @default(PENDING)
  adminRemark  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([createdById, status, createdAt])
}

enum PaymentMode {
  CASH
  GPAY
  BANK_ACCOUNT
}

enum FundStatus {
  PENDING
  APPROVED
  REJECTED
}

model Fund {
  id            String      @id @default(cuid())
  amount        Float
  receivedFrom  String
  paymentMode   PaymentMode
  status        FundStatus  @default(PENDING)
  rejectReason  String?
  approvedById  String?
  approvedAt    DateTime?
  upiId         String?
  accountNumber String?
  fundDate      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fundDate])
  @@index([userId, fundDate])
  @@index([status])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
